{
  "name": "designer-skill-mcp",
  "version": "0.9.0",
  "description": "MCP server that exposes designer-skill — guidance tools, resources, and prompts for designing, refactoring, and enhancing UI.",
  "type": "module",
  "bin": {
    "designer-skill-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "assets/skill",
    "assets/engine",
    "README.md"
  ],
  "scripts": {
    "sync-skill": "node scripts/sync-skill.mjs",
    "build": "npm run sync-skill && tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "design",
    "frontend",
    "ui",
    "designer-skill"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pythoughts-labs/designer-skill.git",
    "directory": "designer-skill-mcp"
  },
  "homepage": "https://github.com/Pythoughts-labs/designer-skill#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
