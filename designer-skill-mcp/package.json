{
  "name": "designer-skill-mcp",
  "version": "0.1.0",
  "description": "MCP server that exposes the Designer-Skill (design, refactor, and enhance UI) to any MCP client — guidance tools/resources/prompt plus an optional Claude-backed apply tool.",
  "type": "module",
  "bin": {
    "designer-skill-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "assets/skill",
    "README.md"
  ],
  "scripts": {
    "sync-skill": "node scripts/sync-skill.mjs",
    "build": "npm run sync-skill && tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "design",
    "frontend",
    "ui",
    "designer-skill"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.103.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
